# Surge 共享配置 — Mac / iPhone 通用
# 规则源: SukkaW/Surge + blackmatrix7/ios_rule_script
# 日期: 2026-07-01

# ─────────────────────────────────────────────
# 代理节点
# ─────────────────────────────────────────────

[Proxy]
US-Snell = snell, 49.51.202.142, 8388, psk=d9f9644ba88c7af6a41803401645f545, version=6, mode=default
US-Hy2 = hysteria2, 49.51.202.142, 443, password=e6rDrhc9GWxGDybeFTGEixQF, download-bandwidth=200, skip-cert-verify=true, sni=bing.com

# ─────────────────────────────────────────────
# 策略组
# ─────────────────────────────────────────────

[Proxy Group]

# 主策略组（手动选择全局出站）
Proxy = select, HK, TW, JP, SG, US, US-Snell, DEVICE:ivanmac, icon-url=https://raw.githubusercontent.com/Irrucky/Tool/main/Surge/icon/surge_2.png, include-all-proxies=0
Stream = select, HK, TW, JP, SG, US, DIRECT, icon-url=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/HKMTMedia.png
Intelligence = select, HK, TW, JP, SG, US, US-Snell, icon-url=https://raw.githubusercontent.com/fmz200/wool_scripts/main/icons/apps/ChatGPT7.png, include-all-proxies=0
Telegram = select, HK, TW, SG, US, icon-url=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Telegram.png
Apple = select, DIRECT, HK, TW, JP, SG, US, icon-url=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Apple_2.png
Microsoft = select, DIRECT, HK, TW, JP, SG, US, icon-url=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Microsoft.png

# Mac 中转：在家 SSID:phony 直连，外出走 Ponte 隧道

# 区域策略组（Smart 自动选优）
HK = smart, include-other-group=Flower Cloud, no-alert=0, hidden=1, include-all-proxies=0, policy-regex-filter=(🇭🇰)|(香港)|(Hong)|(HK), icon-url=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Hong_Kong.png
TW = smart, include-other-group=Flower Cloud, no-alert=0, hidden=1, include-all-proxies=0, policy-regex-filter=(🇨🇳)|(台)|(Tai)|(TW), icon-url=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Taiwan.png
JP = smart, include-other-group=Flower Cloud, no-alert=0, hidden=1, include-all-proxies=0, policy-regex-filter=(🇯🇵)|(日本)|(Japan)|(JP), icon-url=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Japan.png
SG = smart, include-other-group=Flower Cloud, no-alert=0, hidden=1, include-all-proxies=0, policy-regex-filter=(🇸🇬)|(新加)|(Singapore)|(SG), icon-url=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Singapore.png
US = smart, include-other-group=Flower Cloud, no-alert=0, hidden=1, include-all-proxies=0, policy-regex-filter=(🇺🇸)|(美国)|(States)|(US), icon-url=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/United_States.png

# 机场订阅（Flower Cloud）
Flower Cloud = select, policy-path=https://api-huacloud.net/sub?target=surge&ver=4&insert=true&emoji=true&tfo=true&udp=true&surge.doh=true&filename=Flower_SS.conf&url=https%3A%2F%2Fapi.xmancdn.net%2Fosubscribe.php%3Ftoken2%3Dzq45xp4y-4cbc508203rcrgmocn%26sip002%3D1, no-alert=0, hidden=1, include-all-proxies=0, icon-url=https://raw.githubusercontent.com/lige47/QuanX-icon-rule/main/icon/06jichang/FlowerCloud.png

# ─────────────────────────────────────────────
# 规则
# ─────────────────────────────────────────────

[Rule]

# Ponte 内网（在家直连，外出隧道）

# 进程规则（Mac 端生效，iOS 自动忽略）

# 广告拦截（最高优先级）
DOMAIN-SET,https://ruleset.skk.moe/List/domainset/reject.conf,REJECT,extended-matching
RULE-SET,https://ruleset.skk.moe/List/non_ip/reject.conf,REJECT,extended-matching

# 内网 / 国内直连（命中率最高，前置减少规则遍历）
RULE-SET,https://ruleset.skk.moe/List/non_ip/lan.conf,DIRECT
RULE-SET,https://ruleset.skk.moe/List/non_ip/domestic.conf,DIRECT
RULE-SET,https://ruleset.skk.moe/List/non_ip/direct.conf,DIRECT

# 微信 / 企业微信（高频应用）
RULE-SET,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/WeChat/WeChat.list,DIRECT,extended-matching,no-resolve
DOMAIN-SUFFIX,work.weixin.qq.com,DIRECT

# 静态 CDN（jsDelivr / GitHub 等）
DOMAIN-SET,https://ruleset.skk.moe/List/domainset/cdn.conf,Proxy
RULE-SET,https://ruleset.skk.moe/List/non_ip/cdn.conf,Proxy

# 流媒体
RULE-SET,https://ruleset.skk.moe/List/non_ip/stream.conf,Stream

# AIGC（ChatGPT / OpenAI / Claude）
RULE-SET,https://ruleset.skk.moe/List/non_ip/ai.conf,Intelligence
RULE-SET,https://ruleset.skk.moe/List/non_ip/apple_intelligence.conf,Intelligence,extended-matching

# Telegram
RULE-SET,https://ruleset.skk.moe/List/non_ip/telegram.conf,Telegram

# Apple
DOMAIN-SET,https://ruleset.skk.moe/List/domainset/apple_cdn.conf,Apple
RULE-SET,https://ruleset.skk.moe/List/non_ip/apple_services.conf,Apple
RULE-SET,https://ruleset.skk.moe/List/non_ip/apple_cn.conf,DIRECT

# Microsoft
RULE-SET,https://ruleset.skk.moe/List/non_ip/microsoft_cdn.conf,Microsoft
RULE-SET,https://ruleset.skk.moe/List/non_ip/microsoft.conf,Microsoft,extended-matching

# 网易云音乐
RULE-SET,https://ruleset.skk.moe/List/non_ip/neteasemusic.conf,DIRECT

# 软件下载（苹果/微软更新）
DOMAIN-SET,https://ruleset.skk.moe/List/domainset/download.conf,DIRECT
RULE-SET,https://ruleset.skk.moe/List/non_ip/download.conf,DIRECT

# 海外域名
RULE-SET,https://ruleset.skk.moe/List/non_ip/global.conf,Proxy

# --- IP 规则 ---

# 广告 IP
RULE-SET,https://ruleset.skk.moe/List/ip/reject.conf,REJECT-DROP

# 内网 / 国内
RULE-SET,https://ruleset.skk.moe/List/ip/lan.conf,DIRECT
RULE-SET,https://ruleset.skk.moe/List/ip/domestic.conf,DIRECT
RULE-SET,https://ruleset.skk.moe/List/ip/china_ip.conf,DIRECT

# Telegram
RULE-SET,https://ruleset.skk.moe/List/ip/telegram.conf,Telegram
RULE-SET,https://ruleset.skk.moe/List/ip/telegram_asn.conf,Telegram

# 流媒体
RULE-SET,https://ruleset.skk.moe/List/ip/stream.conf,Stream

# 网易云音乐
RULE-SET,https://ruleset.skk.moe/List/ip/neteasemusic.conf,DIRECT

# 兜底
FINAL,Proxy,dns-failed
